{
  "manifest_version": 3,
  "name": "ClaimRadar BG Overlay",
  "short_name": "ClaimRadar BG",
  "version": "2.3.0",
  "description": "Bulgarian claim detection overlay with YouTube captions, selection analysis, local history and optional realtime tab-audio transcription.",
  "homepage_url": "https://dyrakarmy-claimradar-bg.hf.space/product",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "storage", "tabCapture", "offscreen"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://*.youtube.com/*",
    "https://duckduckgo.com/*",
    "https://*.hf.space/*",
    "wss://*.hf.space/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_title": "ClaimRadar BG",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js", "audio_controls.js"],
      "run_at": "document_idle"
    }
  ]
}
